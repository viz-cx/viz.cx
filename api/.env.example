MONGO=mongodb://127.0.0.1:27017
DB_NAME=viz-blockchain
COLLECTION=blocks
ROOT_PATH=
EMIT_TIP_LAG=5
# Comma-separated VIZ node endpoints (first is preferred, rest are failover).
VIZ_NODES=wss://node.viz.cx/ws
# Floor the parser's start position here (minus 1) to skip a hole no reachable
# node can serve. The parser never rewinds below blocks already in the DB.
# Set to ~current head to resume live indexing after falling out of the node's
# get_ops_in_block window; leave at 0 for normal sequential parsing.
PARSER_START_BLOCK=0
